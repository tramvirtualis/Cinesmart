# Sao chép thành backend/.env cho local. KHÔNG commit .env.
# Trên Render: thêm từng biến trong Dashboard → Environment.

# ========== BẮT BUỘC ==========
SPRING_PROFILES_ACTIVE=prod

SPRING_DATASOURCE_URL=jdbc:mysql://HOST:3306/movieticketbooking?useSSL=true&serverTimezone=Asia/Ho_Chi_Minh
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

JWT_SECRET=

# Gmail SMTP — dùng App Password (Google Account → Security → 2-Step → App passwords)
# KHÔNG dùng mật khẩu đăng nhập Gmail thường.
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx

# ========== PAYMENT / OAUTH / KHÁC ==========
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=

MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

APP_FRONTEND_URL=https://cinesmart-movie-ticket-booking.vercel.app
