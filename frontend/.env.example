# Sao chép thành `.env` trong thư mục frontend. Không commit `.env`.
# Vite chỉ expose biến có tiền tố VITE_.

# URL backend API — BẮT BUỘC set trước khi build production (Vercel, Netlify, ...)
# Ví dụ: https://your-backend.onrender.com/api
VITE_API_BASE_URL=

VITE_GOOGLE_CLIENT_ID=

# n8n Webhook Production (Popcorn Bot) — mặc định http://localhost:5678/webhook/popcorn
VITE_N8N_WEBHOOK_URL=
