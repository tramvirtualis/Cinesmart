# Sao chép thành `.env` trong thư mục frontend. Không commit `.env`.
# Vite chỉ expose biến có tiền tố VITE_.

# ========== LOCAL ==========
# VITE_API_BASE_URL=http://localhost:8080/api
# VITE_WS_BASE_URL=http://localhost:8080/ws

# ========== PRODUCTION (Vercel) — BẮT BUỘC set trước khi build ==========
# Frontend: https://cinesmart-movie-ticket-booking.vercel.app
# Backend phải deploy riêng (Render/Railway/VPS...) — KHÔNG dùng URL Vercel cho /api
#
# VITE_API_BASE_URL=https://YOUR-BACKEND-DOMAIN.com/api
# VITE_WS_BASE_URL=https://YOUR-BACKEND-DOMAIN.com/ws

VITE_API_BASE_URL=
VITE_WS_BASE_URL=

VITE_GOOGLE_CLIENT_ID=

# n8n Webhook Production (Popcorn Bot)
VITE_N8N_WEBHOOK_URL=
